# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api
CORS_ORIGIN=http://localhost:5173

# ─── Database (PostgreSQL) ─────────────────────────────
DATABASE_URL=postgresql://erp:erp_password@localhost:5432/erp_panel?schema=public
#postgresql://abhilekhdev:npg_nKxMFO48ihXL@ep-dry-sound-atcfv93s.c-9.us-east-1.aws.neon.tech/erp?sslmode=require&channel_binding=require
# ─── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Auth / JWT (seconds) ──────────────────────────────
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_REFRESH_TTL=2592000
REFRESH_COOKIE_NAME=erp_rt

# ─── Rate limiting ─────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ─── Mail (SMTP) ───────────────────────────────────────
# Same key names as the legacy Laravel .env, so credentials drop straight in.
# Used by: payslip email (HRM > Payroll > Payslip > Send Email) and future notifications.
# Leave MAIL_HOST empty to disable mail — the app still boots and sending returns a clear
# "not configured" error instead of crashing.
# Verify without sending:  GET /api/health/mail   (auth required)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
# 587 = STARTTLS (MAIL_ENCRYPTION=tls) · 465 = implicit TLS (MAIL_ENCRYPTION=ssl)
MAIL_PORT=587
MAIL_USERNAME=you@example.com
# Gmail: this must be a 16-char APP PASSWORD (needs 2FA on the account), NOT your login password.
# Create at: Google Account > Security > 2-Step Verification > App passwords
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=you@example.com
MAIL_FROM_NAME="Your Company"

# ─── S3 (document/file uploads) ────────────────────────
# Leave AWS_BUCKET empty to store uploads on local disk (./uploads) instead of S3.
# Needed for: user documents, and any future file upload.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
# Only for S3-compatible providers (MinIO / DigitalOcean Spaces / Cloudflare R2).
# Leave empty for real AWS S3.
AWS_ENDPOINT=
# MinIO and most self-hosted gateways need this as true; AWS S3 wants false.
AWS_USE_PATH_STYLE_ENDPOINT=false
