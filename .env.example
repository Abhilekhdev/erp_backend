# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api
CORS_ORIGIN=http://localhost:5173

# ─── Database (PostgreSQL) ─────────────────────────────
DATABASE_URL=postgresql://erp:erp_password@localhost:5432/erp_panel?schema=public
#postgresql://abhilekhdev:npg_nKxMFO48ihXL@ep-dry-sound-atcfv93s.c-9.us-east-1.aws.neon.tech/erp?sslmode=require&channel_binding=require
# ─── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Auth / JWT (seconds) ──────────────────────────────
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_REFRESH_TTL=2592000
REFRESH_COOKIE_NAME=erp_rt

# ─── Rate limiting ─────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120
